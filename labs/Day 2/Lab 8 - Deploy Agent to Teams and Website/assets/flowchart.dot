digraph lab {
  graph [label="Lab 8 - Publish Agent and Connect Website", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Marina Trust\\nCopilot agent", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="Publish", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Microsoft Teams", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Website enquiry form", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Ordinary HTTP flow\\n(no agent)", fillcolor="#E8F1FF", color="#1F6FEB"]; n5 [label="Website result", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="channel"]; n1 -> n2 [label="chat"]; n3 -> n4 [label="POST"]; n4 -> n5 [label="JSON response"];
}
