{
  "type": "object",
  "required": [
    "applicationId",
    "decision",
    "reason",
    "riskFlags",
    "emailSent"
  ],
  "properties": {
    "applicationId": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVED",
        "REJECTED",
        "DUPLICATE",
        "REVIEW"
      ]
    },
    "reason": {
      "type": "string"
    },
    "riskFlags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "emailSent": {
      "type": "boolean"
    }
  }
}
