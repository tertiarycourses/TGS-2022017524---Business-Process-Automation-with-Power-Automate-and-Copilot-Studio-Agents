digraph lab {
  graph [label="Lab 7B - Grounded IT Support RAG", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="User question", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="IT Support agent", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Approved IT FAQ\\nknowledge source", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Retrieve relevant passage", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Grounded answer\\nwith citation", fillcolor="#E8F1FF", color="#1F6FEB"]; n5 [label="Refuse unsupported claims", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="ask"]; n1 -> n2 [label="search"]; n2 -> n3 [label="retrieve"]; n3 -> n4 [label="ground"]; n2 -> n5 [label="no evidence"];
}
