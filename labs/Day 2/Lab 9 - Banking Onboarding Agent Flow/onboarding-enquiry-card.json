{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Marina Trust Bank Training Enquiry",
      "weight": "Bolder",
      "size": "Large"
    },
    {
      "type": "TextBlock",
      "text": "Use fictitious details and your own email address.",
      "wrap": true
    },
    {
      "type": "Input.Text",
      "id": "fullName",
      "label": "Full name",
      "isRequired": true,
      "errorMessage": "Enter a name."
    },
    {
      "type": "Input.Text",
      "id": "email",
      "label": "Email",
      "style": "Email",
      "isRequired": true,
      "errorMessage": "Enter a valid email."
    },
    {
      "type": "Input.ChoiceSet",
      "id": "accountType",
      "label": "Account type",
      "isRequired": true,
      "choices": [
        {"title": "Savings", "value": "Savings"},
        {"title": "Current", "value": "Current"},
        {"title": "Fixed Deposit", "value": "Fixed Deposit"},
        {"title": "Multi-Currency", "value": "Multi-Currency"}
      ]
    },
    {
      "type": "Input.ChoiceSet",
      "id": "employmentStatus",
      "label": "Employment status",
      "isRequired": true,
      "choices": [
        {"title": "Employed", "value": "Employed"},
        {"title": "Self-Employed", "value": "Self-Employed"},
        {"title": "Student", "value": "Student"},
        {"title": "Unemployed", "value": "Unemployed"}
      ]
    },
    {
      "type": "Input.Number",
      "id": "annualIncome",
      "label": "Annual income (SGD)",
      "min": 0,
      "isRequired": true
    },
    {
      "type": "Input.Number",
      "id": "initialDeposit",
      "label": "Initial deposit (SGD)",
      "min": 0,
      "isRequired": true
    },
    {
      "type": "Input.ChoiceSet",
      "id": "pep",
      "label": "Politically Exposed Person (training declaration)",
      "isRequired": true,
      "choices": [
        {"title": "No", "value": "No"},
        {"title": "Yes", "value": "Yes"}
      ]
    },
    {
      "type": "Input.ChoiceSet",
      "id": "foreignTaxResident",
      "label": "Foreign tax resident (training declaration)",
      "isRequired": true,
      "choices": [
        {"title": "No", "value": "No"},
        {"title": "Yes", "value": "Yes"}
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Submit enquiry",
      "data": {
        "action": "submitOnboardingEnquiry"
      }
    }
  ]
}
