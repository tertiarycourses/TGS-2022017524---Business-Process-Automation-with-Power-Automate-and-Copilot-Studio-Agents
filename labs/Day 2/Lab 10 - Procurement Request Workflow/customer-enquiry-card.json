{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Marina Trust Customer Enquiry",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "Training simulation only. Do not enter passwords, PINs, OTPs, card numbers or full identity numbers.",
      "wrap": true,
      "color": "Attention"
    },
    {
      "type": "Input.Text",
      "id": "fullName",
      "label": "Full name",
      "isRequired": true,
      "errorMessage": "Enter a name."
    },
    {
      "type": "Input.Text",
      "id": "email",
      "label": "Email",
      "style": "Email",
      "isRequired": true,
      "errorMessage": "Enter a valid email address."
    },
    {
      "type": "Input.ChoiceSet",
      "id": "category",
      "label": "Enquiry category",
      "isRequired": true,
      "choices": [
        {
          "title": "Accounts",
          "value": "Accounts"
        },
        {
          "title": "Cards",
          "value": "Cards"
        },
        {
          "title": "Digital banking",
          "value": "Digital Banking"
        },
        {
          "title": "Fees",
          "value": "Fees"
        },
        {
          "title": "Other",
          "value": "Other"
        }
      ]
    },
    {
      "type": "Input.Text",
      "id": "message",
      "label": "How can we help?",
      "isMultiline": true,
      "maxLength": 1000,
      "isRequired": true,
      "errorMessage": "Describe the enquiry."
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Submit enquiry",
      "data": {
        "action": "submitGeneralEnquiry"
      }
    }
  ]
}
