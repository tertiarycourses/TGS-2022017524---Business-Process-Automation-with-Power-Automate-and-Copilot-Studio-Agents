digraph lab {
  graph [label="Lab 10 - Copilot Agent Calls a Prompt Flow", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Teams or website chat", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="Marina Trust\\nCopilot agent", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Prompt flow tool", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="AI Builder prompt\\nplus guardrails", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Parse and validate", fillcolor="#E8F1FF", color="#1F6FEB"]; n5 [label="Respond to the agent", fillcolor="#E8F1FF", color="#1F6FEB"]; n6 [label="Controlled draft in chat", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="conversation"]; n1 -> n2 [label="confirmed enquiry"]; n2 -> n3 [label="generate"]; n3 -> n4 [label="structured JSON"]; n4 -> n5 [label="safe outputs"]; n5 -> n1 [label="tool result"]; n1 -> n6 [label="present"];
}
