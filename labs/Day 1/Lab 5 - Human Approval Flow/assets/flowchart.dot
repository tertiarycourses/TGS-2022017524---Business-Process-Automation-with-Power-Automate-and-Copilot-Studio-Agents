digraph lab {
  graph [label="Lab 5 - Human Approval with Two Outcomes", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Manual request", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="Start and wait\\nfor approval", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Human decision", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Outcome condition", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Approved email", fillcolor="#E8F1FF", color="#1F6FEB"]; n5 [label="Rejected email", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="submit"]; n1 -> n2 [label="pause"]; n2 -> n3 [label="outcome"]; n3 -> n4 [label="Approve"]; n3 -> n5 [label="Reject"];
}
