digraph lab {
  graph [label="Lab 0 - Shared Course Environment", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Microsoft 365 account", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="Course Sandbox\\nwith Dataverse", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Power Automate", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Copilot Studio", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Ready for Labs 1-10", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="sign in"]; n1 -> n2 [label="select same environment"]; n1 -> n3 [label="select same environment"]; n2 -> n4 [label="verify"]; n3 -> n4 [label="verify"];
}
