digraph lab {
  graph [label="Lab 4 - Automated Form to Email and Excel", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Customer submits\\nMicrosoft Form", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="New response trigger", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Get response details", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Send team email", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Add Excel row", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="response"]; n1 -> n2 [label="Response Id"]; n2 -> n3 [label="Full Name, Email, Message"]; n2 -> n4 [label="map fields"];
}
