digraph lab {
  graph [label="Lab 1 - Prompt-Created Email Automation", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Learner describes flow\\nin natural language", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="Power Automate Copilot\\ncreates draft", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Manual trigger\\nCustomerName", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Send email (V2)", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Outlook inbox", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="prompt"]; n1 -> n2 [label="review and correct"]; n2 -> n3 [label="dynamic content"]; n3 -> n4 [label="deliver"];
}
