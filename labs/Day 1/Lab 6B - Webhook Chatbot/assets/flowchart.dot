digraph lab {
  graph [label="Lab 6B - Deterministic Webhook Chatbot", labelloc=t, fontsize=20, fontname="Arial Bold",
         bgcolor="white", pad=0.3, nodesep=0.35, ranksep=0.55, splines=ortho];
  rankdir=LR;
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11,
        margin="0.20,0.12", penwidth=1.5];
  edge [fontname="Arial", fontsize=9, color="#59636E", fontcolor="#39424E",
        arrowsize=0.75, penwidth=1.2];
  n0 [label="Browser chatbot", fillcolor="#E8F7EF", color="#16845B"]; n1 [label="HTTP POST", fillcolor="#E8F1FF", color="#1F6FEB"]; n2 [label="Parse JSON", fillcolor="#E8F1FF", color="#1F6FEB"]; n3 [label="Normalise message", fillcolor="#E8F1FF", color="#1F6FEB"]; n4 [label="Switch routes", fillcolor="#E8F1FF", color="#1F6FEB"]; n5 [label="JSON bot reply", fillcolor="#E8F1FF", color="#1F6FEB"]; n6 [label="Chat window", fillcolor="#FFF4E5", color="#B56A00"];
  n0 -> n1 [label="message"]; n1 -> n2 [label="body"]; n2 -> n3 [label="clean"]; n3 -> n4 [label="match topic"]; n4 -> n5 [label="response"]; n5 -> n6 [label="render"];
}
